<?xml version="1.0"?>
<robot name="ugv" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="namespace" default="ugv1"/>
  
  <link name="$(arg namespace)/base_link">
    <visual>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <geometry>
        <box size="0.719 0.57861 0.18"/>
      </geometry>
    </visual>
    <collision>
